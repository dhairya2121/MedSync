<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".activities.patient.Dashboard">

    <!-- 1. Included Navbar -->
    <include
        android:id="@+id/navbar"
        layout="@layout/layout_navbar"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. Main Content Area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintTop_toBottomOf="@id/navbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent"
                android:textColor="#9E9E9E"
                android:textSize="16sp" />

            <!-- Recent Hospital Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/recent_hospital_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeColor="#E0E0E0"
                app:strokeWidth="1dp">

                <TextView
                    android:id="@+id/tvNoRecents"
                    android:layout_width="wrap_content"
                    android:layout_margin="20dp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_height="wrap_content"
                    android:text="No Recent Treatments Found"
                    android:textColor="#9E9E9E"
                    android:textSize="20sp" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible"
                    android:id="@+id/btnRecentHospitalCard"
                    android:padding="24dp">
                    <TextView
                        android:id="@+id/tvRecentHospitalName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Hospital Name"
                        android:textColor="#000000"
                        android:textSize="24sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvRecentDoctorName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Dr. Sample"
                        android:textColor="#666666"
                        android:textSize="16sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvRecentHospitalName" />

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_double_right_stroke"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#000000" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="What do You need?"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- GRID SECTION -->
            <GridLayout
                android:id="@+id/departments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="3"
                android:useDefaultMargins="true"
                android:alignmentMode="alignMargins">

                <include android:id="@+id/general" layout="@layout/item_patient_dashboard_grid" />
                <include android:id="@+id/heart"  layout="@layout/item_patient_dashboard_grid" />
                <include android:id="@+id/brain"  layout="@layout/item_patient_dashboard_grid" />

                <!-- Row 2 -->
                <include android:id="@+id/child"  layout="@layout/item_patient_dashboard_grid" />
                <include android:id="@+id/bone"  layout="@layout/item_patient_dashboard_grid" />
                <include android:id="@+id/eye"  layout="@layout/item_patient_dashboard_grid" />

                <!-- Row 3 -->
                <include android:id="@+id/ear"  layout="@layout/item_patient_dashboard_grid" />
                <include android:id="@+id/lungs"  layout="@layout/item_patient_dashboard_grid" />
                <include android:id="@+id/stomach"  layout="@layout/item_patient_dashboard_grid" />
                <include android:id="@+id/kidney"  layout="@layout/item_patient_dashboard_grid" />
                <include android:id="@+id/hormones"  layout="@layout/item_patient_dashboard_grid" />
                <include android:id="@+id/skin"  layout="@layout/item_patient_dashboard_grid" />
                <include android:id="@+id/surgery"  layout="@layout/item_patient_dashboard_grid" />

            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 3. Included Footer -->
    <include
        android:id="@+id/footer"
        layout="@layout/layout_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>