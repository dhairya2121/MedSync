<?xml version="1.0" encoding="utf-8"?>
    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA"
        tools:context=".activities.receptionist.Profile">

        <!-- Scrollable Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/footer"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Profile Image Section -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="30dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btn_profile_image"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_centerHorizontal="true"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardCornerRadius="60dp"
                        app:cardElevation="4dp"
                        app:strokeColor="@color/light_green"
                        app:strokeWidth="2dp">

                        <ImageView
                            android:id="@+id/iv_profile_pic"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_filled_user"
                            app:tint="#BDBDBD" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/btn_profile_image"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="8dp"
                        android:text="Change Photo"
                        android:textColor="@color/dark_green"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Editable Fields using the same layout as activity_hospital -->
                <include
                    android:id="@+id/receptionist_name_card"
                    layout="@layout/view_editable_input" />

                <include
                    android:id="@+id/receptionist_email_card"
                    layout="@layout/view_editable_input" />

                <include
                    android:id="@+id/receptionist_phone_card"
                    layout="@layout/view_editable_input" />

                <!-- Password field (Will need inputType="textPassword" logic in code) -->
                <include
                    android:id="@+id/receptionist_password_card"
                    layout="@layout/view_editable_input" />

                <!-- Logout Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/logout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="40dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:backgroundTint="#FFEBEE"
                    android:text="Log Out"
                    android:textAllCaps="false"
                    android:textColor="#D32F2F"
                    android:textSize="16sp"
                    app:cornerRadius="28dp"
                    app:icon="@drawable/ic_logout"
                    app:iconGravity="textStart"
                    app:iconTint="#D32F2F"
                    app:strokeColor="#FFCDD2"
                    app:strokeWidth="1dp" />

            </LinearLayout>
        </ScrollView>

        <!-- Shared Footer -->
        <include
            android:id="@+id/footer"
            layout="@layout/layout_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>