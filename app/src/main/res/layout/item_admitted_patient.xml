<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvProfileInitial"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_patient_profile_circle"
            android:gravity="center"
            android:text="P"
            android:textColor="#AD1457"
            android:textSize="24sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Patient Name"
            android:textColor="#212121"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tvRoomBadge"
            app:layout_constraintStart_toEndOf="@+id/tvProfileInitial"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTreatmentType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="General Treatment"
            android:textColor="#757575"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@+id/tvPatientName"
            app:layout_constraintStart_toStartOf="@+id/tvPatientName"
            app:layout_constraintTop_toBottomOf="@+id/tvPatientName" />

        <TextView
            android:id="@+id/tvPatientDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Male | 25 yrs"
            android:textColor="#212121"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="@+id/tvTreatmentType"
            app:layout_constraintStart_toStartOf="@+id/tvTreatmentType"
            app:layout_constraintTop_toBottomOf="@+id/tvTreatmentType" />

        <TextView
            android:id="@+id/tvRoomBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_green_status_badge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Room 101"
            android:textColor="@color/hard_green"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
