<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <include android:id="@+id/navbar" layout="@layout/layout_navbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/btn_remove_caretaker"
        app:layout_constraintTop_toBottomOf="@id/navbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView android:id="@+id/tvProfileInitial"
                android:layout_width="80dp" android:layout_height="80dp"
                android:layout_gravity="center" android:gravity="center"
                android:background="@drawable/bg_patient_profile_circle"
                android:text="C" android:textColor="#AD1457" android:textSize="32sp" android:textStyle="bold" />

            <TextView android:id="@+id/tvCareTakerName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:layout_marginTop="12dp"
                android:text="--" android:textColor="@color/black" android:textSize="22sp" android:textStyle="bold" />

            <include android:id="@+id/view_email" layout="@layout/item_viewable_field" />
            <include android:id="@+id/view_phone" layout="@layout/item_viewable_field" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Assigned Patient"
                android:textAllCaps="true"
                android:textColor="#757575"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_patient"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="8dp"
                android:text="View Patient: --"
                android:textColor="@color/hard_green"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_filled_user"
                app:strokeColor="@color/hard_green" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_remove_caretaker"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="Remove Care Taker"
        android:textColor="#D32F2F"
        android:backgroundTint="#FFEBEE"
        app:layout_constraintBottom_toTopOf="@id/footer" />

    <include android:id="@+id/footer" layout="@layout/layout_footer"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>