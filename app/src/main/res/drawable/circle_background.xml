<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- OUTER STROKE (3dp Lime) -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#8bee06"/> <!-- The lime color -->
        </shape>
    </item>

    <!-- INNER STROKE (1dp White) -->
    <!-- We use an inset of 3dp to move it inside the lime stroke -->
    <item android:top="3dp" android:bottom="3dp" android:left="3dp" android:right="3dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF"/> <!-- The white color -->
        </shape>
    </item>

    <!-- MAIN CONTENT (Light Blue Background) -->
    <!-- We use an inset of 4dp (3dp lime + 1dp white) -->
    <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
        <shape android:shape="oval">
            <solid android:color="#E3F2FD"/> <!-- Light Blue background -->
        </shape>
    </item>

</layer-list>